              ) : (
                <>
                  <div style={{ fontWeight: 800, fontSize: 16, color: '#0f172a' }}>Quản lý: {selectedClass.code} - {selectedClass.name}</div>
                  <div style={{ marginTop: 10, display: 'grid', gridTemplateColumns: 'repeat(2, minmax(0, 1fr))', gap: 10 }}>
                    <input value={classEditForm.name} onChange={(e) => setClassEditForm((p) => ({ ...p, name: e.target.value }))} placeholder="Tên lớp" style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                    <select value={classEditForm.status} onChange={(e) => setClassEditForm((p) => ({ ...p, status: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                      <option value="UPCOMING">UPCOMING</option>
                      <option value="ACTIVE">ACTIVE</option>
                      <option value="COMPLETED">COMPLETED</option>
                      <option value="CANCELLED">CANCELLED</option>
                    </select>
                    <input type="date" value={classEditForm.startDate || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, startDate: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                    <input type="date" value={classEditForm.endDate || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, endDate: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                    <input value={classEditForm.schedule || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, schedule: e.target.value }))} placeholder="Lịch học" style={{ gridColumn: '1 / span 2', padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                    <textarea rows={3} value={classEditForm.notes || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, notes: e.target.value }))} placeholder="Ghi chú lớp" style={{ gridColumn: '1 / span 2', resize: 'vertical', padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                    <button onClick={handleSaveClassInfo} disabled={classEditLoading} style={{ gridColumn: '1 / span 2', border: 'none', borderRadius: 10, padding: '10px 12px', color: 'white', fontWeight: 700, background: 'linear-gradient(135deg, #0ea5e9, #0284c7)', cursor: 'pointer' }}>
                      {classEditLoading ? 'Đang lưu...' : 'Lưu thay đổi thông tin lớp'}
                    </button>
                  </div>

                  <div style={{ marginTop: 12 }}>
                    <div style={{ fontWeight: 700, marginBottom: 6 }}>Giảng viên ({(selectedClass.teachers || []).length})</div>
                    <div style={{ display: 'grid', gap: 6, maxHeight: 120, overflowY: 'auto' }}>
                      {(selectedClass.teachers || []).map((t) => (
                        <div key={`${t.id}-${t.role}`} style={{ fontSize: 13, border: '1px solid #e2e8f0', borderRadius: 8, padding: '6px 8px' }}>{t.fullName} • {t.role}</div>
                      ))}
                    </div>
                  </div>

                  <div style={{ marginTop: 12 }}>
                    <div style={{ fontWeight: 700, marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}><Users size={14} /> Học viên ({(selectedClass.students || []).length})</div>
                    <div style={{ maxHeight: 180, overflowY: 'auto', border: '1px solid #f1f5f9', borderRadius: 8 }}>
                      {(selectedClass.students || []).map((s) => (
                        <div key={s.id} style={{ padding: '7px 8px', borderBottom: '1px solid #f8fafc' }}>
                          <div style={{ fontSize: 13, fontWeight: 600 }}>{s.fullName || s.email || s.studentCode}</div>
                          <div style={{ fontSize: 12, color: '#64748b' }}>{s.studentCode ? `Mã: ${s.studentCode} • ` : ''}{s.email || ''}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  );

  return (
    <AdminLayout title="Quản lý giảng viên & lớp" subtitle="Trang quản trị theo luồng: tạo lớp → gán giảng viên → bàn giao học viên → quản lý chi tiết.">
      {body}
    </AdminLayout>
  );
}

    try {
      setHandoverLoading(true);
      const result = await authApi.assignStudentsByClassCodeScoped({
        classCode: handoverForm.classCode.trim(),
        studentCodes,
        notes: handoverForm.notes,
      });

      const failed = Number(result?.failed || 0);
      if (failed > 0) {
        alert(`Đã thêm ${result?.success || 0}, thất bại ${failed}.`);
      } else {
        alert(`Đã thêm thành công ${result?.success || 0} học viên.`);
      }

      setHandoverForm((prev) => ({ ...prev, studentCodesText: '', notes: '' }));
      clearCsv();
      setRefreshTick((v) => v + 1);
    } catch (e) {
      alert(e?.response?.data?.message || 'Thêm học viên thất bại');
    } finally {
      setHandoverLoading(false);
    }
  };

  const handleSaveClassInfo = async () => {
    if (!isAdmin || !selectedClass?.id) return;
    if (!classEditForm.name.trim()) {
      alert('Tên lớp không được để trống');
      return;
    }

    try {
      setClassEditLoading(true);
      await authApi.updateClassInfo(selectedClass.id, {
        name: classEditForm.name,
        status: classEditForm.status,
        startDate: classEditForm.startDate || null,
        endDate: classEditForm.endDate || null,
        level: classEditForm.level,
        targetBand: classEditForm.targetBand,
        classType: classEditForm.classType,
        maxStudents: classEditForm.maxStudents === '' ? null : Number(classEditForm.maxStudents),
        schedule: classEditForm.schedule,
        roomLocation: classEditForm.roomLocation,
        notes: classEditForm.notes,
      });
      alert('Đã cập nhật thông tin lớp');
      setRefreshTick((v) => v + 1);
    } catch (e) {
      alert(e?.response?.data?.message || 'Cập nhật lớp thất bại');
    } finally {
      setClassEditLoading(false);
    }
  };

  const body = (
    <div style={{ display: 'grid', gap: 16 }}>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, minmax(0, 1fr))', gap: 12 }}>
        <div style={{ ...panelStyle, background: 'linear-gradient(135deg, #eff6ff, #ffffff)' }}>
          <div style={{ fontSize: 12, color: '#64748b' }}>Tổng lớp</div>
          <div style={{ fontSize: 28, fontWeight: 800, color: '#1e3a8a' }}>{classes.length}</div>
        </div>
        <div style={{ ...panelStyle, background: 'linear-gradient(135deg, #ecfeff, #ffffff)' }}>
          <div style={{ fontSize: 12, color: '#64748b' }}>Học viên active</div>
          <div style={{ fontSize: 28, fontWeight: 800, color: '#0f766e' }}>{allActiveStudents}</div>
        </div>
        <div style={{ ...panelStyle, background: 'linear-gradient(135deg, #f5f3ff, #ffffff)' }}>
          <div style={{ fontSize: 12, color: '#64748b' }}>Giảng viên</div>
          <div style={{ fontSize: 28, fontWeight: 800, color: '#5b21b6' }}>{teachers.length}</div>
        </div>
      </div>

      {error && (
        <div style={{ ...panelStyle, color: '#dc2626', background: '#fef2f2', borderColor: '#fecaca' }}>{error}</div>
      )}

      <div style={panelStyle}>
        <h3 style={sectionTitleStyle}><PlusCircle size={18} /> 1) Tạo lớp & phân công giảng viên</h3>
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 14 }}>
          <div style={{ border: '1px solid #e2e8f0', borderRadius: 10, padding: 12 }}>
            <div style={{ fontSize: 13, fontWeight: 700, marginBottom: 8, color: '#1e293b' }}>Tạo lớp mới</div>
            <div style={{ display: 'grid', gap: 10 }}>
              <input value={createClassForm.classCode} onChange={(e) => setCreateClassForm((p) => ({ ...p, classCode: e.target.value }))} placeholder="Mã lớp" style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
              <input value={createClassForm.className} onChange={(e) => setCreateClassForm((p) => ({ ...p, className: e.target.value }))} placeholder="Tên lớp" style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
              <input type="date" value={createClassForm.startDate} onChange={(e) => setCreateClassForm((p) => ({ ...p, startDate: e.target.value }))} style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
              <select value={createClassForm.teacherId} onChange={(e) => setCreateClassForm((p) => ({ ...p, teacherId: e.target.value }))} style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                <option value="">(Tuỳ chọn) Chọn GV chính</option>
                {teachers.map((t) => <option key={t.id} value={t.id}>{t.fullName} {t.teacherCode ? `(${t.teacherCode})` : ''}</option>)}
              </select>
              <button onClick={handleCreateClass} disabled={createClassLoading} style={{ border: 'none', borderRadius: 10, padding: '10px 12px', color: 'white', fontWeight: 700, background: 'linear-gradient(135deg, #2563eb, #1d4ed8)', cursor: 'pointer' }}>
                {createClassLoading ? 'Đang tạo...' : 'Tạo lớp'}
              </button>
            </div>
          </div>

          <div style={{ border: '1px solid #e2e8f0', borderRadius: 10, padding: 12 }}>
            <div style={{ fontSize: 13, fontWeight: 700, marginBottom: 8, color: '#1e293b' }}>Phân công giảng viên theo mã lớp</div>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>
              <input value={assignTeacherForm.classCode} onChange={(e) => setAssignTeacherForm((p) => ({ ...p, classCode: e.target.value }))} placeholder="Mã lớp" style={{ gridColumn: '1 / span 2', padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
              <select value={assignTeacherForm.teacherId} onChange={(e) => setAssignTeacherForm((p) => ({ ...p, teacherId: e.target.value }))} style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                <option value="">Chọn giảng viên</option>
                {teachers.map((t) => <option key={t.id} value={t.id}>{t.fullName}</option>)}
              </select>
              <select value={assignTeacherForm.role} onChange={(e) => setAssignTeacherForm((p) => ({ ...p, role: e.target.value }))} style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                <option value="MAIN_TEACHER">MAIN_TEACHER</option>
                <option value="ASSISTANT">ASSISTANT</option>
                <option value="SUBSTITUTE">SUBSTITUTE</option>
              </select>
              <button onClick={handleAssignTeacher} style={{ gridColumn: '1 / span 2', border: 'none', borderRadius: 10, padding: '10px 14px', color: 'white', fontWeight: 700, background: 'linear-gradient(135deg, #16a34a, #15803d)', cursor: 'pointer' }}>Gán GV</button>
            </div>
          </div>
        </div>
      </div>

      <div style={panelStyle}>
        <h3 style={sectionTitleStyle}><ClipboardList size={18} /> 2) Bàn giao học viên vào lớp</h3>
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 14 }}>
          <div style={{ display: 'grid', gap: 10 }}>
            <input value={handoverForm.classCode} onChange={(e) => setHandoverForm((p) => ({ ...p, classCode: e.target.value }))} placeholder="Mã lớp" style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
            <textarea rows={6} value={handoverForm.studentCodesText} onChange={(e) => setHandoverForm((p) => ({ ...p, studentCodesText: e.target.value }))} placeholder="Nhập thủ công mã học viên/username (mỗi dòng một mã)" style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1', resize: 'vertical' }} />
            <input value={handoverForm.notes} onChange={(e) => setHandoverForm((p) => ({ ...p, notes: e.target.value }))} placeholder="Ghi chú (tuỳ chọn)" style={{ padding: '10px 12px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
            <button onClick={handleAssignStudents} disabled={handoverLoading} style={{ border: 'none', borderRadius: 10, padding: '10px 12px', color: 'white', fontWeight: 700, background: 'linear-gradient(135deg, #0ea5e9, #0284c7)', cursor: 'pointer' }}>
              {handoverLoading ? 'Đang xử lý...' : 'Thêm vào lớp'}
            </button>
          </div>

          <div style={{ border: '1px solid #e2e8f0', borderRadius: 8, padding: 10, background: '#f8fafc' }}>
            <div style={{ fontSize: 13, fontWeight: 700, marginBottom: 8 }}>Upload CSV và xem trước</div>
            <input ref={csvInputRef} type="file" accept=".csv,text/csv" onChange={handleCsvUpload} />
            {csvError && <div style={{ marginTop: 8, fontSize: 12, color: '#dc2626' }}>{csvError}</div>}
            {csvCodes.length > 0 && (
              <div style={{ marginTop: 8 }}>
                <div style={{ fontSize: 12, color: '#1e3a8a', fontWeight: 700 }}>{csvFileName} • {csvCodes.length} mã</div>
                <div style={{ maxHeight: 190, overflowY: 'auto', fontSize: 12, marginTop: 6 }}>
                  {csvCodes.slice(0, 120).map((code) => <div key={code} style={{ fontFamily: 'monospace' }}>{code}</div>)}
                  {csvCodes.length > 120 && <div style={{ color: '#64748b' }}>... và {csvCodes.length - 120} mã khác</div>}
                </div>
                <button type="button" onClick={clearCsv} style={{ marginTop: 8, border: '1px solid #cbd5e1', borderRadius: 6, padding: '4px 8px', background: 'white', cursor: 'pointer' }}>Xóa file</button>
              </div>
            )}
          </div>
        </div>
      </div>

      <div style={{ ...panelStyle, paddingBottom: 10 }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 10 }}>
          <h3 style={{ margin: 0, display: 'flex', alignItems: 'center', gap: 8 }}><School size={18} /> 3) Danh sách lớp & quản lý chi tiết</h3>
          <div style={{ display: 'flex', gap: 8 }}>
            <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Tìm lớp theo mã/tên..." style={{ padding: '8px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
            <button onClick={() => setRefreshTick((v) => v + 1)} style={{ border: '1px solid #cbd5e1', borderRadius: 8, padding: '8px 10px', background: 'white', cursor: 'pointer' }}><RefreshCw size={14} /></button>
          </div>
        </div>

        {loading ? (
          <div>Đang tải dữ liệu...</div>
        ) : (
          <>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1.25fr', gap: 12 }}>
              <div style={{ maxHeight: 560, overflowY: 'auto', paddingRight: 4 }}>
                <div style={{ display: 'grid', gridTemplateColumns: '1fr', gap: 10 }}>
              {filteredClasses.map((c) => (
                <div
                  key={c.id}
                  style={{
                    border: c.id === selectedClass?.id ? '2px solid #3b82f6' : '1px solid #e2e8f0',
                    borderRadius: 12,
                    padding: 12,
                    background: '#fff',
                  }}
                >
                  <div style={{ fontWeight: 800, color: '#0f172a', marginBottom: 4 }}>{c.code}</div>
                  <div style={{ fontWeight: 600, color: '#1e293b', marginBottom: 6 }}>{c.name}</div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                    <span style={statusBadgeStyle(c.status)}>{c.status || 'N/A'}</span>
                    <span style={{ fontSize: 12, color: '#64748b' }}>{c.activeStudentCount || 0} học viên</span>
                  </div>
                  <div style={{ fontSize: 12, color: '#64748b', marginTop: 2 }}>Bắt đầu: {c.startDate || 'N/A'}</div>
                  <button
                    onClick={() => setSelectedClassId(c.id)}
                    style={{
                      marginTop: 10,
                      width: '100%',
                      border: 'none',
                      borderRadius: 9,
                      padding: '9px 10px',
                      background: 'linear-gradient(135deg, #2563eb, #1d4ed8)',
                      color: 'white',
                      fontWeight: 700,
                      cursor: 'pointer',
                    }}
                  >
                    Quản lý lớp này
                  </button>
                </div>
              ))}
              {filteredClasses.length === 0 && <div style={{ color: '#64748b' }}>Không có lớp phù hợp</div>}
            </div>

            <div style={{ border: '1px solid #e2e8f0', borderRadius: 10, padding: 12 }}>
              {!selectedClass ? (
                <div style={{ color: '#64748b' }}>Chọn một module lớp để quản lý.</div>
              ) : (
                <>
                  <div style={{ fontWeight: 800, fontSize: 16, color: '#0f172a' }}>Quản lý: {selectedClass.code} - {selectedClass.name}</div>

                  {isAdmin && (
                    <div style={{ marginTop: 10, display: 'grid', gridTemplateColumns: 'repeat(2, minmax(0, 1fr))', gap: 10 }}>
                      <input value={classEditForm.name} onChange={(e) => setClassEditForm((p) => ({ ...p, name: e.target.value }))} placeholder="Tên lớp" style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <select value={classEditForm.status} onChange={(e) => setClassEditForm((p) => ({ ...p, status: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                        <option value="UPCOMING">UPCOMING</option>
                        <option value="ACTIVE">ACTIVE</option>
                        <option value="COMPLETED">COMPLETED</option>
                        <option value="CANCELLED">CANCELLED</option>
                      </select>
                      <input type="date" value={classEditForm.startDate || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, startDate: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <input type="date" value={classEditForm.endDate || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, endDate: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <input value={classEditForm.level || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, level: e.target.value }))} placeholder="Level" style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <input value={classEditForm.targetBand || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, targetBand: e.target.value }))} placeholder="Target band" style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <select value={classEditForm.classType || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, classType: e.target.value }))} style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }}>
                        <option value="">Class type</option>
                        <option value="OFFLINE">OFFLINE</option>
                        <option value="ONLINE">ONLINE</option>
                        <option value="HYBRID">HYBRID</option>
                      </select>
                      <input type="number" min={1} value={classEditForm.maxStudents} onChange={(e) => setClassEditForm((p) => ({ ...p, maxStudents: e.target.value }))} placeholder="Sĩ số tối đa" style={{ padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <input value={classEditForm.schedule || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, schedule: e.target.value }))} placeholder="Lịch học" style={{ gridColumn: '1 / span 2', padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <input value={classEditForm.roomLocation || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, roomLocation: e.target.value }))} placeholder="Phòng học / Link" style={{ gridColumn: '1 / span 2', padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <textarea rows={3} value={classEditForm.notes || ''} onChange={(e) => setClassEditForm((p) => ({ ...p, notes: e.target.value }))} placeholder="Ghi chú lớp" style={{ gridColumn: '1 / span 2', resize: 'vertical', padding: '9px 10px', borderRadius: 8, border: '1px solid #cbd5e1' }} />
                      <button onClick={handleSaveClassInfo} disabled={classEditLoading} style={{ gridColumn: '1 / span 2', border: 'none', borderRadius: 10, padding: '10px 12px', color: 'white', fontWeight: 700, background: 'linear-gradient(135deg, #0ea5e9, #0284c7)', cursor: 'pointer' }}>
                        {classEditLoading ? 'Đang lưu...' : 'Lưu thay đổi thông tin lớp'}
                      </button>
                    </div>
                  )}

                  <div style={{ marginTop: 12 }}>
                    <div style={{ fontWeight: 700, marginBottom: 6 }}>Giảng viên ({(selectedClass.teachers || []).length})</div>
                    <div style={{ display: 'grid', gap: 6, maxHeight: 120, overflowY: 'auto' }}>
                      {(selectedClass.teachers || []).map((t) => (
                        <div key={`${t.id}-${t.role}`} style={{ fontSize: 13, border: '1px solid #e2e8f0', borderRadius: 8, padding: '6px 8px' }}>
                          {t.fullName} • {t.role}
                        </div>
                      ))}
                      {(selectedClass.teachers || []).length === 0 && <div style={{ fontSize: 12, color: '#64748b' }}>Chưa có giảng viên</div>}
                    </div>
                  </div>

                  <div style={{ marginTop: 12 }}>
                    <div style={{ fontWeight: 700, marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                      <Users size={14} /> Học viên ({(selectedClass.students || []).length})
                    </div>
                    <div style={{ maxHeight: 180, overflowY: 'auto', border: '1px solid #f1f5f9', borderRadius: 8 }}>
                      {(selectedClass.students || []).map((s) => (
                        <div key={s.id} style={{ padding: '7px 8px', borderBottom: '1px solid #f8fafc' }}>
                          <div style={{ fontSize: 13, fontWeight: 600 }}>{s.fullName || s.email || s.studentCode}</div>
                          <div style={{ fontSize: 12, color: '#64748b' }}>
                            {s.studentCode ? `Mã: ${s.studentCode} • ` : ''}
                            {s.email || ''}
                          </div>
                        </div>
                      ))}
                      {(selectedClass.students || []).length === 0 && <div style={{ padding: 8, fontSize: 12, color: '#64748b' }}>Chưa có học viên</div>}
                    </div>
                  </div>
                </>
              )}
            </div>
          </>
        )}
      </div>
    </div>
  );

                </div>
              </div>
  return (
            <div style={{ border: '1px solid #e2e8f0', borderRadius: 10, padding: 12 }}>
      {body}
    </AdminLayout>
  );
}

*/
