# ===================================================================
# DAVictory — Production / Native Environment
# Su dung: ./manage.sh start
# Xem .env.docker cho Docker.
# ===================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=1111
MYSQL_DATABASE=DAVictory

# --- Database (all services connect to this) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1111
DB_NAME=DAVictory
JWT_SECRET=change_this_to_a_different_production_secret_please

# --- AI Service URLs (Backend goi sang AI services) ---
AI_SERVICE_URL=http://localhost:5182
AI_SPEAKING_SERVICE_URL=http://localhost:5181
AI_IMPORT_SERVICE_URL=http://localhost:5186
AI_AGENT_SERVICE_URL=http://localhost:5187

# --- Frontend proxy targets (localhost cho native) ---
AI_WRITING_HOST=localhost
AI_SPEAKING_HOST=localhost
AI_IMPORT_HOST=localhost
AI_AGENT_HOST=localhost

# --- Google Drive ---
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=https://your-production-domain.com/api/drive/oauth2callback
GOOGLE_DRIVE_FRONTEND_URL=https://your-production-domain.com
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# --- Groq API (primary LLM provider) ---
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEYS=
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL=qwen/qwen3-32b
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=16384

# --- NVIDIA API (fallback LLM provider) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_TEMPERATURE=0.1
NVIDIA_MAX_TOKENS=8192

# --- OpenAI (via Groq for Whisper/TTS) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_STT_MODEL=whisper-large-v3
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- Unsplash (AI Agent blog images) ---
UNSPLASH_ACCESS_KEY=

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=5184

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Quotas ---
QUOTA_STUDENT_PER_DAY=5
QUOTA_TEACHER_PER_DAY=50
QUOTA_ADMIN_PER_DAY=200

# --- AI Import -> Backend callback ---
BACKEND_URL=http://localhost:8080

# --- AI Agent Uploads Dir ---
AI_AGENT_UPLOADS_DIR=/app/uploads
