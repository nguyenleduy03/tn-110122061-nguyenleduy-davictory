# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=DAVictory

# Groq API (primary provider)
GROQ_API_KEY=gsk_your_key_here
GROQ_API_KEY_2=
GROQ_API_KEYS=
GROQ_MODEL=qwen/qwen3-32b
GROQ_TEMPERATURE=0.1

# NVIDIA API (fallback provider)
NVIDIA_API_KEY=nvapi_your_key_here
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_TEMPERATURE=0.1

# Redis (optional - falls back to in-memory queue)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=5187
