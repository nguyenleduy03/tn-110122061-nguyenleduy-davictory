# ===================================================================
# DAVictory — Docker Environment Variables
# FILE: .env.example
# USAGE: cp .env.example .env  (then edit .env with your real values)
# Sau do chay: docker compose up -d
# ===================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=DAVictory

# --- Database (all services connect to this) ---
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=DAVictory
JWT_SECRET=changeme_use_a_long_random_base64_string_here
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=https://your-domain.com/api/drive/oauth2callback
GOOGLE_DRIVE_FRONTEND_URL=https://your-domain.com
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# --- AI Service URLs (Backend goi sang AI services) ---
AI_SERVICE_URL=http://ai-writing-python:5182
AI_SPEAKING_SERVICE_URL=http://ai-speaking-python:5181
AI_IMPORT_SERVICE_URL=http://ai-import-python:5186
AI_AGENT_SERVICE_URL=http://ai-agent-python:5187

# --- Groq API (primary LLM provider) ---
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEYS=
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL=qwen/qwen3-32b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=16384
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=troy

# --- NVIDIA API (fallback LLM provider) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_TEMPERATURE=0.1
NVIDIA_MAX_TOKENS=8192

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_STT_MODEL=whisper-large-v3
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_SCORING_MODEL=gpt-4o
OPENAI_SCORING_TEMPERATURE=0.1
OPENAI_SCORING_MAX_TOKENS=2048

# --- Gemini ---
GEMINI_API_KEY=

# --- Unsplash (AI Agent blog images) ---
UNSPLASH_ACCESS_KEY=

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Quotas ---
QUOTA_STUDENT_PER_DAY=5
QUOTA_TEACHER_PER_DAY=50
QUOTA_ADMIN_PER_DAY=200

# --- AI Import -> Backend callback ---
BACKEND_URL=http://backend:8080
BACKEND_TIMEOUT=60

# --- AI Agent ---
AI_AGENT_UPLOADS_DIR=/app/uploads
UPLOAD_DIR=uploads

# --- Scoring ---
SCORING_PROVIDER=nvidia

# --- Writing Service ---
PROMPT_VERSION=v2.0
FEW_SHOT_COUNT=1
MAX_ESSAY_LENGTH=4000

# --- Speaking Service ---
MIN_WORD_CONFIDENCE=0.6
EXPECTED_SPEECH_RATE_MIN=80
EXPECTED_SPEECH_RATE_MAX=160
SESSION_MAX_TURNS=50
SESSION_MAX_DURATION_MINUTES=30

# --- Import Service ---
TESSERACT_CMD=tesseract
OCR_LANGUAGE=eng
OCR_MIN_TEXT_LENGTH=100

# --- Cache ---
CACHE_TTL_MINUTES=1440
CACHE_MAX_SIZE=1000
