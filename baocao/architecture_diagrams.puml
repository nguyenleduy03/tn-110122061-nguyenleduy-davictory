@startuml Kiến trúc bảo mật
title Sơ đồ kiến trúc bảo mật

actor "User" as User
participant "React\nFrontend" as Frontend
participant "JWT Filter" as JwtFilter
participant "Spring Security" as Security
participant "Controllers" as Controller
participant "Services" as Service
database "MySQL" as DB

== Đăng nhập ==
User -> Frontend: Nhập username, password
Frontend -> Controller: POST /api/auth/login\n{username, password}
Controller -> Service: authenticate()
Service -> DB: SELECT user WHERE username=?
DB --> Service: User data
Service -> Service: BCrypt.checkPassword()
Service --> Controller: User object
Controller -> Security: Generate JWT token
Security --> Controller: JWT token
Controller --> Frontend: {token, user}
Frontend -> Frontend: localStorage.setItem('token')

== Gọi API với JWT ==
User -> Frontend: Thực hiện action
Frontend -> Frontend: Get token from localStorage
Frontend -> JwtFilter: API call với\nHeader: Authorization: Bearer {token}
JwtFilter -> JwtFilter: Extract token
JwtFilter -> Security: Validate token
Security -> Security: Check signature\nCheck expiration
alt Token hợp lệ
    Security --> JwtFilter: Valid
    JwtFilter -> Controller: Forward request
    Controller -> Service: Process request
    Service -> DB: Query data
    DB --> Service: Data
    Service --> Controller: Result
    Controller --> Frontend: Response
    Frontend --> User: Display result
else Token không hợp lệ
    Security --> JwtFilter: Invalid
    JwtFilter --> Frontend: 401 Unauthorized
    Frontend -> Frontend: Clear token
    Frontend --> User: Redirect to login
end

@enduml

@startuml Kiến trúc cơ sở dữ liệu
title Sơ đồ kiến trúc cơ sở dữ liệu - Các nhóm bảng chính

package "User Management" {
    entity "user" as user {
        * id : BIGINT
        --
        username : VARCHAR
        password : VARCHAR
        email : VARCHAR
        full_name : VARCHAR
    }
    
    entity "role" as role {
        * id : BIGINT
        --
        name : VARCHAR
    }
    
    entity "user_roles" as user_roles {
        * user_id : BIGINT
        * role_id : BIGINT
    }
}

package "Test Management" {
    entity "test" as test {
        * id : BIGINT
        --
        title : VARCHAR
        description : TEXT
        test_type : VARCHAR
        status : VARCHAR
    }
    
    entity "session" as session {
        * id : BIGINT
        --
        name : VARCHAR
        skill_type : VARCHAR
    }
    
    entity "part" as part {
        * id : BIGINT
        --
        session_id : BIGINT
        name : VARCHAR
    }
    
    entity "question_group" as qgroup {
        * id : BIGINT
        --
        part_id : BIGINT
        passage_content : TEXT
        audio_url : VARCHAR
    }
    
    entity "question" as question {
        * id : BIGINT
        --
        question_group_id : BIGINT
        question_type_id : BIGINT
        question_text : TEXT
    }
}

package "Exam Attempt" {
    entity "exam_attempt" as attempt {
        * id : BIGINT
        --
        user_id : BIGINT
        test_id : BIGINT
        status : VARCHAR
        band_score : DECIMAL
    }
    
    entity "attempt_answer" as answer {
        * id : BIGINT
        --
        exam_attempt_id : BIGINT
        question_id : BIGINT
        answer_text : TEXT
        is_correct : BOOLEAN
    }
    
    entity "student_writing_submission" as writing {
        * id : BIGINT
        --
        user_id : BIGINT
        question_group_id : BIGINT
        content : TEXT
        band_score : DECIMAL
    }
}

package "Class Management" {
    entity "class" as class {
        * id : BIGINT
        --
        code : VARCHAR
        name : VARCHAR
        start_date : DATE
    }
    
    entity "class_student" as class_student {
        * id : BIGINT
        --
        class_id : BIGINT
        user_id : BIGINT
    }
    
    entity "assignment" as assignment {
        * id : BIGINT
        --
        class_id : BIGINT
        test_id : BIGINT
        due_date : TIMESTAMP
    }
    
    entity "assignment_submission" as submission {
        * id : BIGINT
        --
        assignment_id : BIGINT
        user_id : BIGINT
        exam_attempt_id : BIGINT
    }
}

' Relationships
user ||--o{ user_roles
role ||--o{ user_roles

test ||--o{ attempt
user ||--o{ attempt
attempt ||--o{ answer
question ||--o{ answer

test ||--o{ session
session ||--o{ part
part ||--o{ qgroup
qgroup ||--o{ question

user ||--o{ writing
qgroup ||--o{ writing

class ||--o{ class_student
user ||--o{ class_student

class ||--o{ assignment
test ||--o{ assignment

assignment ||--o{ submission
user ||--o{ submission
attempt ||--o{ submission

@enduml

