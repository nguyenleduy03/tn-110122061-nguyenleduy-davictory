@startuml Kiến trúc tổng quan hệ thống
!define RECTANGLE class

title Sơ đồ kiến trúc tổng quan - Hệ thống DAVictory IELTS

skinparam rectangle {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<database>> LightYellow
    BackgroundColor<<external>> LightPink
}

actor "Học viên" as Student
actor "Giáo viên" as Teacher
actor "Admin" as Admin
actor "Khách" as Guest

package "Frontend Layer" <<frontend>> {
    rectangle "React Application\n(Port 5173)" as React {
        rectangle "Pages" as Pages
        rectangle "Components" as Components
        rectangle "Services" as Services
        rectangle "Hooks" as Hooks
    }
}

package "Backend Layer" <<backend>> {
    rectangle "Spring Boot Application\n(Port 8080)" as SpringBoot {
        rectangle "Controllers\n(REST API)" as Controllers
        rectangle "Services\n(Business Logic)" as BusinessServices
        rectangle "Repositories\n(Data Access)" as Repositories
        rectangle "Security\n(JWT + Spring Security)" as Security
    }
}

package "Database Layer" <<database>> {
    database "MySQL\n(Port 3306)" as MySQL {
        rectangle "Users & Roles" as UserDB
        rectangle "Tests & Questions" as TestDB
        rectangle "Exam Attempts" as ExamDB
        rectangle "Classes & Assignments" as ClassDB
    }
}

package "External Services" <<external>> {
    cloud "Google Drive API" as GoogleDrive
    cloud "Email Service\n(SMTP)" as Email
}

Student --> React : "Truy cập web"
Teacher --> React : "Truy cập web"
Admin --> React : "Truy cập web"
Guest --> React : "Truy cập web"

React --> Controllers : "HTTP/REST API\n(JSON)"
Controllers --> Security : "Xác thực JWT"
Security --> Controllers : "Token valid"

Controllers --> BusinessServices : "Gọi business logic"
BusinessServices --> Repositories : "Truy vấn dữ liệu"
Repositories --> MySQL : "JDBC/JPA"

BusinessServices --> GoogleDrive : "Upload/Download files"
BusinessServices --> Email : "Gửi thông báo"

note right of React
  **Frontend Tech Stack:**
  - React 19.2.0
  - Vite 8.0
  - Axios (HTTP Client)
  - React Router
end note

note right of SpringBoot
  **Backend Tech Stack:**
  - Spring Boot 4.0.3
  - Spring Security + JWT
  - Spring Data JPA
  - Java 21
end note

note right of MySQL
  **Database:**
  - MySQL 8.0
  - 30+ tables
  - Indexes & Foreign Keys
end note

@enduml

