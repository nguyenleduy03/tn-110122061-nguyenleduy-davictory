@startuml Đăng nhập
title Sơ đồ tuần tự - Đăng nhập

actor "Người dùng" as User
participant "LoginPage\n(React)" as UI
participant "AuthController" as Controller
participant "UserService" as Service
participant "JwtUtil" as JWT
database "MySQL" as DB

User -> UI: Nhập username, password
User -> UI: Click "Đăng nhập"
activate UI

UI -> Controller: POST /api/auth/login\n{username, password}
activate Controller

Controller -> Service: authenticate(username, password)
activate Service

Service -> DB: SELECT * FROM user\nWHERE username = ?
activate DB
DB --> Service: User data
deactivate DB

Service -> Service: BCrypt.checkPassword()
alt Mật khẩu đúng
    Service --> Controller: User object
    deactivate Service
    
    Controller -> JWT: generateToken(username)
    activate JWT
    JWT --> Controller: JWT token
    deactivate JWT
    
    Controller --> UI: 200 OK\n{token, user}
    deactivate Controller
    
    UI -> UI: localStorage.setItem('token')
    UI --> User: Chuyển đến Dashboard
    deactivate UI
else Mật khẩu sai
    Service --> Controller: throw BadCredentialsException
    Controller --> UI: 401 Unauthorized
    UI --> User: Hiển thị lỗi
end

@enduml

@startuml Đăng ký
title Sơ đồ tuần tự - Đăng ký tài khoản

actor "Người dùng" as User
participant "RegisterPage\n(React)" as UI
participant "AuthController" as Controller
participant "UserService" as Service
database "MySQL" as DB

User -> UI: Nhập thông tin đăng ký
User -> UI: Click "Đăng ký"
activate UI

UI -> Controller: POST /api/auth/register\n{username, email, password, fullName}
activate Controller

Controller -> Service: registerUser(request)
activate Service

Service -> DB: SELECT * FROM user\nWHERE username = ?
activate DB
DB --> Service: null (chưa tồn tại)
deactivate DB

Service -> Service: BCrypt.hashPassword(password)

Service -> DB: INSERT INTO user\n(username, email, password_hash, full_name)
activate DB
DB --> Service: User ID
deactivate DB

Service -> DB: INSERT INTO user_roles\n(user_id, role_id)\nVALUES (?, STUDENT_ROLE_ID)
activate DB
DB --> Service: Success
deactivate DB

Service --> Controller: User object
deactivate Service

Controller --> UI: 200 OK\n{message: "Đăng ký thành công"}
deactivate Controller

UI --> User: Hiển thị thông báo thành công\nChuyển đến trang đăng nhập
deactivate UI

@enduml

@startuml Tạo đề thi
title Sơ đồ tuần tự - Tạo đề thi (Test Builder)

actor "Giáo viên" as Teacher
participant "TestBuilderPage\n(React)" as UI
participant "TestBuilderController" as Controller
participant "TestBuilderService" as Service
participant "GoogleDriveService" as Drive
database "MySQL" as DB

Teacher -> UI: Nhập thông tin đề thi\n(title, description, test_type)
Teacher -> UI: Thêm Session (Listening/Reading/Writing/Speaking)
Teacher -> UI: Thêm Part vào Session
Teacher -> UI: Tạo Question Group\n(passage, instructions)
Teacher -> UI: Upload file audio/image
activate UI

UI -> Drive: Upload file media
activate Drive
Drive --> UI: File URL từ Google Drive
deactivate Drive

Teacher -> UI: Thêm câu hỏi\n(Multiple Choice, Fill Blank, etc.)
Teacher -> UI: Nhập đáp án đúng
Teacher -> UI: Click "Lưu đề thi"

UI -> Controller: POST /api/test-builder/save\n{test, sessions, parts, questionGroups, questions}
activate Controller

Controller -> Service: saveFullTest(request)
activate Service

Service -> DB: INSERT INTO test\n(title, description, test_type, status)
activate DB
DB --> Service: test_id
deactivate DB

loop Cho mỗi Session
    Service -> DB: INSERT INTO test_session\n(test_id, session_id, order_index)
    activate DB
    DB --> Service: test_session_id
    deactivate DB
    
    loop Cho mỗi Part
        Service -> DB: INSERT INTO test_part\n(test_session_id, part_id, order_index)
        activate DB
        DB --> Service: test_part_id
        deactivate DB
        
        loop Cho mỗi Question Group
            Service -> DB: INSERT INTO question_group\n(part_id, title, passage_content, audio_url)
            activate DB
            DB --> Service: question_group_id
            deactivate DB
            
            loop Cho mỗi Question
                Service -> DB: INSERT INTO question\n(question_group_id, question_type_id, question_text)
                activate DB
                DB --> Service: question_id
                deactivate DB
                
                alt Multiple Choice
                    Service -> DB: INSERT INTO question_option\n(question_id, option_text, is_correct)
                    DB --> Service: Success
                else Fill Blank / Short Answer
                    Service -> DB: INSERT INTO answer\n(question_id, answer_text)
                    DB --> Service: Success
                else Matching
                    Service -> DB: INSERT INTO matching_pair\n(question_group_id, left_item, right_item)
                    DB --> Service: Success
                end
            end
        end
    end
end

Service --> Controller: Test object với ID
deactivate Service

Controller --> UI: 200 OK\n{testId, message: "Lưu thành công"}
deactivate Controller

UI --> Teacher: Hiển thị thông báo thành công\nChuyển đến trang xem đề thi
deactivate UI

@enduml

@startuml Làm bài thi
title Sơ đồ tuần tự - Làm bài thi

actor "Học viên" as Student
participant "ExamPage\n(React)" as UI
participant "ExamAttemptController" as Controller
participant "ExamAttemptService" as Service
database "MySQL" as DB

Student -> UI: Chọn đề thi
Student -> UI: Click "Bắt đầu làm bài"
activate UI

UI -> Controller: POST /api/exam-attempt/start\n{userId, testId, sessionId}
activate Controller

Controller -> Service: startAttempt(request)
activate Service

Service -> DB: INSERT INTO exam_attempt\n(user_id, test_id, session_id, status, started_at)
activate DB
DB --> Service: attempt_id
deactivate DB

Service -> DB: SELECT * FROM question\nWHERE test_id = ?
activate DB
DB --> Service: List<Question>
deactivate DB

loop Cho mỗi câu hỏi
    Service -> DB: INSERT INTO attempt_answer\n(exam_attempt_id, question_id, is_answered)
    activate DB
    DB --> Service: Success
    deactivate DB
end

Service --> Controller: ExamAttempt object
deactivate Service

Controller --> UI: 200 OK\n{attemptId, questions, timeLimit}
deactivate Controller

UI --> Student: Hiển thị câu hỏi đầu tiên\nBắt đầu đếm ngược thời gian
deactivate UI

== Trong quá trình làm bài ==

loop Mỗi 30 giây (Auto-save)
    UI -> Controller: PUT /api/exam-attempt/{attemptId}/save-progress\n{answers}
    activate Controller
    Controller -> Service: saveProgress(attemptId, answers)
    activate Service
    Service -> DB: UPDATE attempt_answer\nSET answer_text = ?, selected_option_id = ?\nWHERE id = ?
    activate DB
    DB --> Service: Success
    deactivate DB
    Service --> Controller: Success
    deactivate Service
    Controller --> UI: 200 OK
    deactivate Controller
end

== Nộp bài ==

Student -> UI: Click "Nộp bài"
activate UI

UI -> Controller: POST /api/exam-attempt/{attemptId}/submit\n{answers}
activate Controller

Controller -> Service: submitAttempt(attemptId, answers)
activate Service

Service -> DB: UPDATE attempt_answer\nSET answer_text = ?, selected_option_id = ?, is_answered = true
activate DB
DB --> Service: Success
deactivate DB

Service -> Service: gradeAttempt(attemptId)

Service -> DB: SELECT * FROM attempt_answer\nWHERE exam_attempt_id = ?
activate DB
DB --> Service: List<AttemptAnswer>
deactivate DB

loop Cho mỗi câu trả lời
    Service -> DB: SELECT correct answer
    activate DB
    DB --> Service: Correct answer
    deactivate DB
    
    Service -> Service: Compare answer
    
    Service -> DB: UPDATE attempt_answer\nSET is_correct = ?, points_earned = ?
    activate DB
    DB --> Service: Success
    deactivate DB
end

Service -> Service: calculateBandScore(correctCount, totalQuestions)

Service -> DB: UPDATE exam_attempt\nSET status = 'SUBMITTED',\nsubmitted_at = NOW(),\ntotal_score = ?,\nband_score = ?
activate DB
DB --> Service: Success
deactivate DB

Service --> Controller: ExamAttempt với kết quả
deactivate Service

Controller --> UI: 200 OK\n{bandScore, totalScore, correctCount}
deactivate Controller

UI --> Student: Hiển thị kết quả\n(Band score, số câu đúng/sai)
deactivate UI

@enduml

