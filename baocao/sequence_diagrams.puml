@startuml Xem thống kê
title Sơ đồ tuần tự - Xem thống kê và báo cáo

actor "Giáo viên" as Teacher
participant "StatisticsPage\n(React)" as UI
participant "ClassManagementController" as Controller
participant "ClassService" as Service
database "MySQL" as DB

Teacher -> UI: Chọn lớp học
Teacher -> UI: Click "Xem thống kê"
activate UI

UI -> Controller: GET /api/classes/{classId}/statistics
activate Controller

Controller -> Service: getClassStatistics(classId)
activate Service

Service -> DB: SELECT COUNT(*) FROM class_student\nWHERE class_id = ?
activate DB
DB --> Service: totalStudents
deactivate DB

Service -> DB: SELECT AVG(ea.band_score)\nFROM exam_attempt ea\nJOIN assignment_submission asub ON ea.id = asub.exam_attempt_id\nJOIN assignment a ON asub.assignment_id = a.id\nWHERE a.class_id = ?
activate DB
DB --> Service: averageBandScore
deactivate DB

Service -> DB: SELECT COUNT(*) FROM assignment\nWHERE class_id = ?
activate DB
DB --> Service: totalAssignments
deactivate DB

Service -> DB: SELECT COUNT(*) FROM assignment_submission asub\nJOIN assignment a ON asub.assignment_id = a.id\nWHERE a.class_id = ? AND asub.status = 'GRADED'
activate DB
DB --> Service: completedSubmissions
deactivate DB

Service -> DB: SELECT u.full_name, AVG(ea.band_score) as avg_score\nFROM user u\nJOIN class_student cs ON u.id = cs.user_id\nLEFT JOIN assignment_submission asub ON u.id = asub.user_id\nLEFT JOIN exam_attempt ea ON asub.exam_attempt_id = ea.id\nWHERE cs.class_id = ?\nGROUP BY u.id
activate DB
DB --> Service: List<StudentScore>
deactivate DB

Service --> Controller: ClassStatistics object
deactivate Service

Controller --> UI: 200 OK\n{totalStudents, averageScore, assignments, studentScores}
deactivate Controller

UI --> Teacher: Hiển thị:\n- Tổng số học viên\n- Điểm trung bình lớp\n- Biểu đồ phân bố điểm\n- Bảng xếp hạng học viên\n- Tỷ lệ hoàn thành Assignment
deactivate UI

@enduml

@startuml Thi thử cho khách
title Sơ đồ tuần tự - Thi thử cho khách (Guest Exam)

actor "Khách" as Guest
participant "GuestExamPage\n(React)" as UI
participant "GuestExamController" as Controller
participant "GuestExamService" as Service
database "MySQL" as DB

Guest -> UI: Truy cập trang thi thử
activate UI

UI -> Controller: GET /api/guest-exam/available-tests
activate Controller

Controller -> Service: getAvailableGuestTests()
activate Service

Service -> DB: SELECT * FROM test\nWHERE status = 'PUBLISHED'\nAND is_guest_allowed = true
activate DB
DB --> Service: List<Test>
deactivate DB

Service --> Controller: List<Test>
deactivate Service

Controller --> UI: 200 OK\n{tests}
deactivate Controller

UI --> Guest: Hiển thị danh sách đề thi thử
deactivate UI

Guest -> UI: Chọn đề thi
Guest -> UI: Nhập email
Guest -> UI: Click "Bắt đầu làm bài"
activate UI

UI -> Controller: POST /api/guest-exam/start\n{testId, email}
activate Controller

Controller -> Service: startGuestExam(testId, email)
activate Service

Service -> DB: SELECT COUNT(*) FROM guest_exam_attempt\nWHERE email = ? AND test_id = ?\nAND DATE(started_at) = CURDATE()
activate DB
DB --> Service: attemptCount
deactivate DB

alt attemptCount < 3
    Service -> DB: INSERT INTO guest_exam_attempt\n(test_id, email, status, started_at)
    activate DB
    DB --> Service: attempt_id
    deactivate DB
    
    Service -> DB: SELECT * FROM question\nWHERE test_id = ?
    activate DB
    DB --> Service: List<Question>
    deactivate DB
    
    Service --> Controller: GuestExamAttempt
    deactivate Service
    
    Controller --> UI: 200 OK\n{attemptId, questions}
    deactivate Controller
    
    UI --> Guest: Hiển thị câu hỏi\nBắt đầu làm bài
    deactivate UI
else Đã hết lượt thi
    Service --> Controller: throw LimitExceededException
    Controller --> UI: 429 Too Many Requests
    UI --> Guest: "Bạn đã hết lượt thi thử hôm nay"
end

== Nộp bài ==

Guest -> UI: Click "Nộp bài"
activate UI

UI -> Controller: POST /api/guest-exam/{attemptId}/submit\n{answers}
activate Controller

Controller -> Service: submitGuestExam(attemptId, answers)
activate Service

Service -> Service: gradeAnswers(answers)

Service -> DB: UPDATE guest_exam_attempt\nSET status = 'SUBMITTED',\nsubmitted_at = NOW(),\nband_score = ?
activate DB
DB --> Service: Success
deactivate DB

Service --> Controller: GuestExamResult
deactivate Service

Controller --> UI: 200 OK\n{bandScore, correctCount, totalQuestions}
deactivate Controller

UI --> Guest: Hiển thị kết quả\n(Band score, số câu đúng)\nGửi kết quả qua email
deactivate UI

@enduml
